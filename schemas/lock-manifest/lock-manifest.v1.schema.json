{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/lock-manifest/lock-manifest.v1.schema.json",
  "title": "EV4 Project Gate Lock Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "transition_id", "files"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["lock-manifest.v1", "external-contract-lock.v1"]
    },
    "transition_id": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/lockFile"
      }
    }
  },
  "$defs": {
    "lockFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "repository", "accepted_commit", "path", "contract_or_schema_id", "sha256_file_bytes"],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "accepted_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "contract_or_schema_id": {
          "type": "string",
          "minLength": 1
        },
        "sha256_file_bytes": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
