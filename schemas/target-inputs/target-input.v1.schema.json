{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EV4 Target Input Package v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_id", "target_stage", "source", "transition", "target", "evidence", "provenance"],
  "properties": {
    "schema_version": { "const": "target-input.v1" },
    "package_id": { "type": "string", "minLength": 1 },
    "target_stage": { "type": "string", "enum": ["ce", "builder", "responsive"] },
    "source": { "type": "object", "additionalProperties": true, "required": ["bundle_id", "stage", "source_hash"] },
    "transition": { "type": "object", "additionalProperties": false, "required": ["id", "version"], "properties": { "id": { "type": "string" }, "version": { "type": "string" } } },
    "target": { "type": "object", "additionalProperties": true, "required": ["project", "handoff"] },
    "evidence": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": true } },
    "provenance": { "type": "object", "additionalProperties": true, "required": ["source_stage", "target_stage", "transition_id", "transition_version", "source_hash", "output_hash", "tool", "tool_version"] }
  }
}
