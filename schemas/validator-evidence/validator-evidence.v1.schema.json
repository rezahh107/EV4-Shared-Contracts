{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://ev4.local/schemas/validator-evidence/validator-evidence.v1.schema.json","title":"EV4 Project Gate Validator Evidence v1","type":"object","additionalProperties":false,"required":["schema_version","validator_id","owner_repository","validator_path","execution_id","status","validated_stage","validated_scope","validated_hash","result_digest"],"properties":{"schema_version":{"const":"validator-evidence.v1"},"validator_id":{"type":"string","minLength":1},"owner_repository":{"type":"string","pattern":"^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},"accepted_commit":{"type":"string","pattern":"^[a-f0-9]{40}$"},"validator_file_hash":{"type":"string","pattern":"^[a-f0-9]{64}$"},"validator_path":{"type":"string","minLength":1},"execution_id":{"type":"string","minLength":1},"status":{"const":"passed"},"validated_stage":{"type":"string","enum":["architect","ce","builder","responsive"]},"validated_scope":{"type":"string","enum":["source_bundle","payload"]},"validated_hash":{"type":"string","pattern":"^[a-f0-9]{64}$"},"result_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"}},"anyOf":[{"required":["accepted_commit"]},{"required":["validator_file_hash"]}]}
